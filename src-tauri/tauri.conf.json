{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "arcade-launcher",
  "version": "0.1.0",
  "identifier": "nyc.steamcenter.arcade-launcher",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "arcade-launcher",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgxNEVDOTZEODVERTRENzcKUldSM1RkNkZiY2xPZ2ZtMDBlTVRxQnUraXJDa3hOY285SUtuZHRvTHFQU0FoS0tWUk9jZ0p0Qm0K",
      "endpoints": [
        "https://github.com/Brooklyn-STEAM/arcade-launcher/releases/latest/download/latest.json"
      ]
    }
  }
}
